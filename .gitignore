*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# -------------------
# Testing
# -------------------
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# -------------------
# Jupyter
# -------------------
.ipynb_checkpoints

# -------------------
# Virtual environments
# -------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
fyers-env/

# -------------------
# IDEs
# -------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -------------------
# OS artefacts
# -------------------
.DS_Store
Thumbs.db

# =============================================================================
# SECURITY – CRITICAL: these files contain credentials and MUST NOT be committed
# =============================================================================
config.ini
config copy.ini
token.enc
token.key
*.key
*.pem
*.enc
secrets/
.secrets/
.env.local
.env.production

# Fyers credentials / session data
tokens.json
session/

# =============================================================================
# User data – runtime files that are personal / machine-specific
# =============================================================================
data/*.md
data/*.tsv
!data/.gitkeep

logs/
output/
reports/
batch/

# Fyers API log files
*.log

# Large media files (demo GIFs etc.)
*.mp4
demo.gif

# Selenium drivers
driver/
chromedriver
geckodriver

# =============================================================================
# NOTE: config/trading_profile.yml contains API credentials.
#       Commit ONLY config/trading_profile.example.yml (template without secrets).
# =============================================================================
config/trading_profile.yml
